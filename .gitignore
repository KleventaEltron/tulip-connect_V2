# MPLAB X build directories (ignore output files)
tulip_connect.X/nbproject/private/
tulip_connect.X/nbproject/Package-*

# Keep project configuration files tracked
!tulip_connect.X/nbproject/Makefile
!tulip_connect.X/nbproject/configurations.xml
!tulip_connect.X/tulip_connect.X.cproj

# Ignore build artifacts
tulip_connect.X/dist/
tulip_connect.X/debug/
tulip_connect.X/queuelogs/
tulip_connect.X/build/
tulip_connect.X/.generated_files/flags/default/
tulip_connect.X/.generated_files/flags/debug/

# Ignore sensitive files
src/files/credentials.h

# Ignore common build artifacts
*.elf
*.hex
*.cof
*.map
*.o
*.d
*.s
*.lst
*.gld
*.a
*.S

# Ignore debugging files
*.dSYM/
*.pdb
*.log

# Ignore MPLABX auto-generated files
*.dep
*.iobj
*.o.d
*.lst
*.ps
*.err
*.idb
*.map
*.sym
*.asm

# Ignore temporary files
*.bak
*.swp
*.swo
*.tmp
*.cache

# macOS specific files
.DS_Store

# Windows specific files
Thumbs.db